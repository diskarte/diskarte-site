---
import Base from '../layouts/Base.astro';
import { notFoundPage } from '../copy/meta';
const t = notFoundPage.en;
const j = notFoundPage.ja;
---
<Base locale="en" title={t.title} description={t.h1} noindex>
  <section class="section" style="border:none;min-height:50vh">
    <div class="wrap" style="max-width:720px">
      <p class="mono" style="font-size:.8rem;color:var(--faint);letter-spacing:.1em">404</p>
      <h1 style="margin-top:12px">{t.h1}</h1>
      <p class="lede" style="margin-top:12px">{t.p}</p>
      <p class="muted" style="margin-top:8px">{j.h1} {j.p}</p>
      <div style="display:flex;gap:12px;margin-top:26px;flex-wrap:wrap">
        <a class="btn primary" href="/">{t.home}</a>
        <a class="btn" href="/ja">{j.home}</a>
      </div>
    </div>
  </section>
</Base>
