---
interface Props { text: string; sub?: string; dark?: boolean }
const { text, sub, dark = false } = Astro.props;
---
<section class={`section doctrine-section ${dark ? 'on-dark' : ''}`}>
  <div class="wrap">
    <p class="doctrine reveal">{text}</p>
    {sub && <p class="doctrine-sub reveal">{sub}</p>}
  </div>
</section>
<style>
  .doctrine-section { padding-block: clamp(56px, 8vw, 100px); }
  .doctrine-section.on-dark .doctrine { color: #f2f4f7; }
</style>
