---
import Base from '../../layouts/Base.astro';
import { overviewPage } from '../../copy/meta';
import { routes, type Locale } from '../../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = overviewPage[locale];
const previews = [
  ['/technical-overview/preview-1.webp', locale === 'ja' ? '表紙' : 'Cover'],
  ['/technical-overview/preview-6.webp', locale === 'ja' ? '「欠けているレイヤー」図' : 'The missing layer diagram'],
  ['/technical-overview/preview-25.webp', locale === 'ja' ? 'エビデンス・真実・カノン' : 'Evidence, truth, and canon'],
  ['/technical-overview/preview-51.webp', locale === 'ja' ? 'サブストレート・シーム' : 'The substrate seam'],
  ['/technical-overview/preview-54.webp', locale === 'ja' ? 'マネージド・アプライアンス' : 'The managed appliance'],
];
---
<Base locale={locale} title={t.meta.title} description={t.meta.description}>
  <section class="section" style="border:none">
    <div class="wrap split">
      <div>
        <p class="eyebrow">{t.hero.eyebrow}</p>
        <h1 style="margin-top:14px;font-size:clamp(2rem,4.6vw,3.1rem)">{t.hero.h1}</h1>
        <p class="lede" style="margin-top:18px">{t.hero.lede}</p>
        <div class="facts">
          {t.facts.map(([n, l]) => (
            <div class="fact"><span class="n">{n}</span><span class="l">{l}</span></div>
          ))}
        </div>
      </div>
      <div class="pv reveal">
        <img src={previews[0][0]} alt={previews[0][1]} width="880" height="495" loading="eager" decoding="async" style="width:100%;height:auto;border-radius:12px;border:1px solid var(--line);box-shadow:var(--shadow)" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head"><h2>{t.tocHead}</h2></div>
      <div class="grid2" style="max-width:960px">
        {t.toc.map((item) => (
          <div class="toc-item reveal">{item}</div>
        ))}
      </div>
      <p class="muted" style="margin-top:26px;max-width:70ch">{t.read}</p>
      <div class="strip">
        {previews.slice(1).map(([src, alt]) => (
          <img src={src} alt={alt} width="440" height="248" loading="lazy" decoding="async" />
        ))}
      </div>
      <p style="margin-top:26px"><a href={routes.architecture[locale]}>{t.explore} →</a></p>
    </div>
  </section>
</Base>

<style>
  .facts { display: flex; gap: 26px; margin-top: 30px; flex-wrap: wrap; }
  .fact { display: flex; flex-direction: column; }
  .fact .n { font-size: 1.8rem; font-weight: 800; letter-spacing: -0.03em; }
  .fact .l { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
  .toc-item {
    border: 1px solid var(--line); background: var(--surface); border-radius: 10px;
    padding: 12px 16px; font-size: 0.92rem; font-weight: 500;
  }
  .strip { display: grid; gap: 12px; grid-template-columns: repeat(2, 1fr); margin-top: 30px; }
  @media (min-width: 860px) { .strip { grid-template-columns: repeat(4, 1fr); } }
  .strip img { width: 100%; height: auto; border-radius: 8px; border: 1px solid var(--line); }
</style>
