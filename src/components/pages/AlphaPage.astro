---
import Base from '../../layouts/Base.astro';
import StatusChip from '../StatusChip.astro';
import { alphaPage } from '../../copy/meta';
import Waitlist from '../Waitlist.astro';
import { ui, type Locale } from '../../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = alphaPage[locale];
const u = ui[locale];
---
<Base locale={locale} title={t.meta.title} description={t.meta.description}>
  <section class="section" style="border:none">
    <div class="wrap" style="max-width:820px">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1 style="margin-top:14px;font-size:clamp(2rem,4.6vw,3.1rem)">{t.hero.h1}</h1>
      <p class="lede" style="margin-top:18px">{t.hero.lede}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="section-head"><h2>{t.stageHead}</h2></div>
      <div class="grid2">
        {t.stage.map((s) => (
          <div class="card card-pad reveal">
            <div style="display:flex;justify-content:space-between;gap:12px;align-items:start;flex-wrap:wrap">
              <h3 style="font-size:1.05rem;max-width:34ch">{s.s}</h3>
              <StatusChip kind={s.kind as 'impl' | 'plan'} locale={locale} />
            </div>
            <p class="muted" style="margin-top:10px;font-size:.9rem">{s.d}</p>
          </div>
        ))}
      </div>
      <p class="muted small" style="margin-top:22px;max-width:72ch">{u.statusKey}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap split">
      <div>
        <div class="section-head" style="margin-bottom:18px"><h2>{t.fitHead}</h2><p class="lede">{t.fitLede}</p></div>
        <ul class="fitlist">
          {t.fit.map((f) => <li class="reveal">{f}</li>)}
        </ul>
      </div>
      <div class="card card-pad" style="align-self:center">
        <h3>{t.expectHead}</h3>
        <p class="muted" style="margin-top:12px;font-size:.94rem">{t.expect}</p>
      </div>
    </div>
  </section>

  <section class="section on-dark">
    <div class="wrap" style="max-width:760px">
      <h2>{t.formHead}</h2>
      <p style="margin-top:14px">{t.formLede}</p>
      <Waitlist locale={locale} />
    </div>
  </section>
</Base>

<style>
  .fitlist { list-style: none; }
  .fitlist li {
    padding: 12px 0 12px 30px; border-bottom: 1px solid var(--line);
    position: relative; font-size: 0.98rem;
  }
  .fitlist li::before {
    content: ''; position: absolute; left: 4px; top: 20px;
    width: 9px; height: 9px; border-radius: 99px; background: var(--steel);
  }
  .fitlist li:last-child { border-bottom: none; }
</style>
