---
import Base from '../../layouts/Base.astro';
import DoctrineQuote from '../DoctrineQuote.astro';
import CtaSection from '../CtaSection.astro';
import { architecture } from '../../copy/depth';
import { type Locale } from '../../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = architecture[locale];
---
<Base locale={locale} title={t.meta.title} description={t.meta.description}>
  <section class="section" style="border:none">
    <div class="wrap" style="max-width:820px">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1 style="margin-top:14px;font-size:clamp(2rem,4.6vw,3.1rem)">{t.hero.h1}</h1>
      <p class="lede" style="margin-top:18px">{t.hero.lede}</p>
    </div>
  </section>

  <section class="section">
    <div class="wrap arch-list">
      {t.concepts.map((c, i) => (
        <article class="concept reveal">
          <div class="num mono" aria-hidden="true">{String(i + 1).padStart(2, '0')}</div>
          <div>
            <h2 style="font-size:1.35rem">{c.h}</h2>
            <p class="muted" style="margin-top:10px">{c.p}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <DoctrineQuote dark text={t.doctrineText} sub={t.doctrineSub} />
  <CtaSection locale={locale} title={t.ctaTitle} body={t.ctaBody} />
</Base>

<style>
  .arch-list { max-width: 860px; display: flex; flex-direction: column; }
  .concept {
    display: grid; grid-template-columns: 56px 1fr; gap: 18px;
    padding-block: clamp(22px, 3.4vw, 34px); border-bottom: 1px solid var(--line);
  }
  .concept:last-child { border-bottom: none; }
  .num { color: var(--muted); font-size: 0.9rem; font-weight: 600; padding-top: 6px; }
</style>
