---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { notesPage } from '../../copy/meta';
import { routes, type Locale } from '../../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = notesPage[locale];
const all = await getCollection('notes', ({ data }) => data.lang === locale && !data.draft);
const notes = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const base = routes.notes[locale];
const fmt = new Intl.DateTimeFormat(locale === 'ja' ? 'ja-JP' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base locale={locale} title={t.meta.title} description={t.meta.description}>
  <section class="section" style="border:none">
    <div class="wrap" style="max-width:820px">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1 style="margin-top:14px;font-size:clamp(2rem,4.6vw,3.1rem)">{t.hero.h1}</h1>
      <p class="lede" style="margin-top:18px">{t.hero.lede}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap" style="max-width:860px">
      {notes.length === 0 && <p class="muted">{t.empty}</p>}
      <div class="note-list">
        {notes.map((n) => (
          <a class="note reveal" href={`${base}/${n.id.replace(/\.(en|ja)$/, '')}`}>
            <div class="meta mono">
              <span>{fmt.format(n.data.date)}</span>
              <span>·</span>
              <span>{n.data.category}</span>
              <span>·</span>
              <span>{n.data.readingTime}{locale === 'ja' ? '' : ` ${t.minutes}`}</span>
            </div>
            <h2 style="font-size:1.35rem;margin-top:8px">{n.data.title}</h2>
            <p class="muted" style="margin-top:8px;font-size:.94rem">{n.data.summary}</p>
            <span style="margin-top:12px;display:inline-block;font-weight:600;color:var(--steel)">{t.read} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
<style>
  .note-list { display: flex; flex-direction: column; }
  .note {
    display: block; text-decoration: none; color: var(--ink);
    padding-block: clamp(22px, 3.4vw, 32px); border-bottom: 1px solid var(--line);
  }
  .note:first-child { padding-top: 0; }
  .note .meta { font-size: 0.7rem; letter-spacing: 0.08em; color: var(--muted); display: flex; gap: 8px; text-transform: uppercase; }
</style>
