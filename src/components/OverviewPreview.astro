---
import { routes, type Locale } from '../i18n/ui';
interface Props { locale: Locale; title: string; body: string; explore: string }
const { locale, title, body, explore } = Astro.props;
const pages = [
  { src: '/technical-overview/preview-1.webp', alt: locale === 'ja' ? '技術概要 表紙' : 'Technical Overview cover page' },
  { src: '/technical-overview/preview-25.webp', alt: locale === 'ja' ? '証拠→真実→カノンの図解ページ' : 'Evidence, truth, and canon diagram page' },
  { src: '/technical-overview/preview-51.webp', alt: locale === 'ja' ? 'サブストレート・シームの図解ページ' : 'Substrate seam architecture diagram page' },
];
---
<div class="tov">
  <div class="pages" aria-hidden="false">
    {pages.map((p, i) => (
      <img src={p.src} alt={p.alt} width="440" height="248" loading="lazy" decoding="async" class={`pg pg-${i} reveal`} />
    ))}
  </div>
  <div class="meta reveal">
    <h3>{title}</h3>
    <p>{body}</p>
    <div class="row">
      <a class="btn" href={routes.architecture[locale]}>{explore}</a>
    </div>
  </div>
</div>
<style>
  .tov { display: grid; gap: 30px; grid-template-columns: 1fr; align-items: center; }
  @media (min-width: 900px) { .tov { grid-template-columns: 6fr 5fr; } }
  .pages { position: relative; min-height: 240px; }
  .pg { border-radius: 10px; border: 1px solid var(--line); box-shadow: var(--shadow); width: min(72%, 440px); height: auto; }
  .pg-0 { position: relative; z-index: 3; }
  .pg-1 { position: absolute; top: 34px; left: 20%; z-index: 2; opacity: 0.95; }
  .pg-2 { position: absolute; top: 68px; left: 33%; z-index: 1; opacity: 0.9; }
  .meta p { margin-top: 12px; color: var(--muted); }
  .row { display: flex; gap: 12px; margin-top: 22px; flex-wrap: wrap; }
</style>
