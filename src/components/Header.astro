---
import { ui, routes, altPath, waitlistHref, type Locale } from '../i18n/ui';
interface Props { locale: Locale }
const { locale } = Astro.props;
const t = ui[locale];
const other: Locale = locale === 'en' ? 'ja' : 'en';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const switchHref = altPath(path, other);
const nav = [
  { href: routes.runtime[locale], label: t.nav.runtime },
  { href: routes.architecture[locale], label: t.nav.architecture },
  { href: routes.notes[locale], label: t.nav.notes },
  { href: routes.about[locale], label: t.nav.about },
  { href: routes.alpha[locale], label: t.nav.alpha },
];
---
<header class="site-header">
  <div class="wrap bar">
    <a class="brand" href={routes.home[locale]} aria-label="Diskarte — home">
      <svg width="22" height="22" viewBox="0 0 64 64" aria-hidden="true"><rect width="64" height="64" rx="14" fill="#13171D"/><rect x="14" y="14" width="36" height="10" rx="3" fill="#7FA0C8"/><rect x="14" y="28" width="36" height="10" rx="3" fill="#3D5A80"/><rect x="14" y="42" width="22" height="10" rx="3" fill="#40506B"/></svg>
      <span>Diskarte</span>
    </a>
    <nav class="desktop-nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} aria-current={path === n.href ? 'page' : undefined}>{n.label}</a>
      ))}
    </nav>
    <div class="actions">
      <a class="lang" href={switchHref} data-lang-switch={other} aria-label={t.langSwitchTo}>
        {other === 'ja' ? '日本語' : 'EN'}
      </a>
      <a class="btn primary small-btn" href={waitlistHref(locale)}>{t.cta.alpha}</a>
      <button class="menu-btn" aria-expanded="false" aria-controls="mobile-nav" data-menu-btn>
        <span class="menu-label">{t.menu}</span>
        <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true"><path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
  <nav id="mobile-nav" class="mobile-nav" hidden aria-label="Primary mobile">
    {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    <a href={switchHref} data-lang-switch={other}>{other === 'ja' ? '日本語' : 'English'}</a>
    <a class="btn primary" href={waitlistHref(locale)}>{t.cta.alpha}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--line);
  }
  .bar { display: flex; align-items: center; gap: 20px; height: 64px; }
  .brand {
    display: inline-flex; align-items: center; gap: 10px;
    font-weight: 700; font-size: 1.05rem; letter-spacing: -0.02em;
    color: var(--ink); text-decoration: none;
  }
  .desktop-nav { display: none; gap: 22px; margin-left: 10px; }
  .desktop-nav a {
    color: var(--muted); text-decoration: none; font-size: 0.92rem; font-weight: 500;
  }
  .desktop-nav a:hover, .desktop-nav a[aria-current='page'] { color: var(--ink); }
  .actions { margin-left: auto; display: flex; align-items: center; gap: 14px; }
  .lang {
    font-family: var(--mono); font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.06em; color: var(--muted); text-decoration: none;
    border: 1px solid var(--line); border-radius: 999px; padding: 5px 12px;
    background: var(--surface);
  }
  .lang:hover { color: var(--ink); border-color: var(--faint); }
  .small-btn { padding: 8px 16px; font-size: 0.85rem; display: none; }
  .menu-btn {
    display: inline-flex; align-items: center; gap: 8px;
    background: none; border: 1px solid var(--line); border-radius: 8px;
    padding: 7px 10px; color: var(--ink); cursor: pointer; font-family: var(--sans);
  }
  .menu-label { font-size: 0.8rem; font-weight: 600; }
  .mobile-nav[hidden] { display: none; }
  .mobile-nav {
    display: flex; flex-direction: column; gap: 4px;
    padding: 10px 24px 22px; border-bottom: 1px solid var(--line);
    background: var(--bg);
  }
  .mobile-nav a {
    text-decoration: none; color: var(--ink); font-weight: 600;
    padding: 10px 0; border-bottom: 1px solid var(--line); font-size: 1rem;
  }
  .mobile-nav a.btn { border: 1.5px solid var(--ink); margin-top: 14px; justify-content: center; }
  @media (min-width: 980px) {
    .desktop-nav { display: flex; }
    .small-btn { display: inline-flex; }
    .menu-btn { display: none; }
  }
</style>

<script>
  const btn = document.querySelector('[data-menu-btn]');
  const nav = document.getElementById('mobile-nav');
  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    if (nav) nav.hidden = open;
  });
  document.querySelectorAll('[data-lang-switch]').forEach((a) => {
    a.addEventListener('click', () => {
      localStorage.setItem('diskarte-locale', a.getAttribute('data-lang-switch') || 'en');
    });
  });
</script>
